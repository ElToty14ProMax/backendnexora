APP_NAME=Nexora
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
# Laravel also accepts Neon/Vercel's DATABASE_URL automatically.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nexora
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=prefer
# Keep enabled for Neon pooled connections/PgBouncer.
DB_DISABLE_PREPARES=true
DB_EMULATE_PREPARES=false
# Optional Neon fallback for older PostgreSQL clients.
# Use the first host label exactly; pooled hosts usually end in -pooler.
# PGOPTIONS=endpoint=your-neon-endpoint-id

NEXORA_ENV=dev
NEXORA_ADMIN_TOKEN=change-this-admin-token-with-32-plus-chars
NEXORA_DATA_KEY_B64=
NEXORA_CPF_PEPPER=change-this-long-random-cpf-pepper
# Use only a bank-generated random Pix key (EVP UUID v4). CPF, email, and phone Pix keys are not accepted.
NEXORA_ADMIN_PIX_KEY=
NEXORA_PIX_MERCHANT_NAME=NEXORA
NEXORA_PIX_MERCHANT_CITY=SAO PAULO
NEXORA_CONTRIBUTION_EXPIRATION_MINUTES=5
NEXORA_SUPER_ADMIN_EMAIL=admin@nexora.local
NEXORA_SUPER_ADMIN_CPF=00000000000
NEXORA_SUPER_ADMIN_PASSWORD=
NEXORA_FOUNDER_EMAILS=admin@nexora.local
NEXORA_CORS_ORIGINS=*

# Receita Federal CPF Validation
# Provedor: infosimples, cpfcnpj, directd
NEXORA_RECEITA_API_PROVIDER=infosimples
NEXORA_RECEITA_API_TOKEN=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# OCR / IA - Análise de comprovantes Pix
# Opções: tesseract (OCR local), ocrspace (API grátis com chave), google, openai.
# Use mock apenas em local/testes com OCR_ALLOW_MOCK=true e OCR_MOCK_TEXT definido.
OCR_PROVIDER=ocrspace
OCR_SPACE_API_KEY=
OCR_SPACE_LANGUAGE=por
OCR_SPACE_ENGINE=2
GOOGLE_VISION_API_KEY=
OPENAI_API_KEY=
TESSERACT_CMD=tesseract
OCR_ALLOW_MOCK=false
OCR_MOCK_TEXT=

# Vercel/serverless production overrides:
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://your-vercel-project.vercel.app
# LOG_CHANNEL=stderr
# SESSION_DRIVER=array
# CACHE_STORE=array
# QUEUE_CONNECTION=sync
# DB_HOST=your-managed-postgres-host
# DB_SSLMODE=require
